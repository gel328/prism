{
  "name": "prism",
  // Source pointer for the @cloudflare/vite-plugin, which validates this at
  // config-load time. Vite then builds the worker into dist/prism/index.js
  // and writes a deploy-ready dist/prism/wrangler.json next to it.
  // Production deploys MUST use that generated config instead of this one
  // (otherwise wrangler re-bundles the source and skips Vite's SSR work).
  // See scripts/build.sh — it copies the generated config back here so a
  // plain `wrangler deploy` from the build directory picks up the right
  // bundle without needing custom flags in the Cloudflare dashboard.
  "main": "worker/index.ts",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    // Default is "auto-trailing-slash", which auto-resolves "/" to
    // "/index.html" and serves the prebuilt template before the worker
    // even runs — defeating SSR. "none" disables that implicit HTML
    // routing; explicitly-requested files (e.g. /index.html, /favicon.svg,
    // /assets/index-XXX.js) are still served from the bundle as static.
    "html_handling": "none",
  },
  "observability": {
    "enabled": true,
  },
  // D1 Database
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "prism-db",
      "database_id": "5790c075-635c-470f-a166-8b9f145ec311",
      "migrations_dir": "worker/db/migrations",
    },
  ],
  // KV Namespaces
  "kv_namespaces": [
    {
      "binding": "KV_SESSIONS",
      "id": "e76739c67270401e8f7b5283cf22d2dd",
    },
    {
      "binding": "KV_CACHE",
      "id": "db4d8187fc3f48eabc412a3f5654fa69",
    },
  ],
  // R2 Bucket
  /*
  "r2_buckets": [
    {
      "binding": "R2_ASSETS",
      "bucket_name": "prism-assets",
    },
  ],
  */
  // Cloudflare Secrets Store. After creating a 32-byte
  // base64url-encoded AES-GCM key in the dashboard, redeploy and use
  // Admin Panel → Settings → Danger Zone → "Migrate secrets to Secret
  // Store" to encrypt existing OAuth client/source secrets in D1.
  // Generate the key with e.g.
  //   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
  "secrets_store_secrets": [
    {
      "binding": "SECRETS_KEY",
      "store_id": "5ffcfaec1c6c4599989fb6a761d9583f",
      "secret_name": "prism-secrets-key",
    },
  ],
  // Environment variables (non-secret)
  "vars": {
    "APP_URL": "https://prism.siiway.org",
  },
  "routes": [
    {
      "pattern": "prism.siiway.org",
      "custom_domain": true,
    },
  ],
  // Re-verify domains every 6 hours
  "triggers": {
    "crons": ["0 */6 * * *"],
  },
}
